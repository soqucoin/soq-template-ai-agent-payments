# Soqucoin AI Agent Micropayments template.
#
# Leave LSP_URL unset to run the LOCAL simulation (no network, instant).
# Set it to the stagenet Lightning Service Provider to make real channel payments.
# LSP_URL=https://lsp.soqu.org
#
# Optional: an explicit L1 settlement address. If omitted, one is derived from the
# agent's post-quantum key.
# SETTLEMENT_ADDR=ssq1...

# ---- SOQ-402 demo (npm run soq402) ----
# With no keys set, a clearly-labelled built-in mock answers, so the payment loop
# still runs end to end. Set any of these to bill for a real model; with two
# different vendors set, the two agents converse across vendors.
# XAI_API_KEY=            # Grok (https://api.x.ai/v1), model via XAI_MODEL
# GEMINI_API_KEY=         # Gemini OpenAI-compat endpoint, model via GEMINI_MODEL
# ANTHROPIC_API_KEY=      # Claude OpenAI-compat layer, model via ANTHROPIC_MODEL
# OPENAI_API_KEY=         # OpenAI, model via OPENAI_MODEL
#
# Or point at anything OpenAI-compatible (Ollama, vLLM, your own gateway):
# UPSTREAM_BASE_URL=http://localhost:11434/v1
# UPSTREAM_MODEL=llama3.2
# UPSTREAM_API_KEY=
# UPSTREAM_NAME=ollama
#
# SOQ402_ROUNDS=3         # conversation rounds (2 messages each)
# SOQ402_PRICE_SAT=333    # price per message, shors
# SOQ402_HOLD=1           # keep gateways + console up after the conversation

# ---- hosted live demo (npm run soq402:live) ----
# AMBIENT_INTERVAL_MIN=10   # minutes between ambient agent conversations
# AMBIENT_ROUNDS=1          # rounds per ambient conversation (2 paid messages each)
# DAILY_INFERENCE_CAP=600   # hard stop on upstream inferences per UTC day
# ASKS_PER_IP_PER_HOUR=6    # visitor question rate limit
# TURNSTILE_SITE_KEY=       # Cloudflare Turnstile (unset = widget off, dev mode)
# TURNSTILE_SECRET=
# TRUST_PROXY=1             # only behind a reverse proxy you control
